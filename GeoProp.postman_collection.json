    {
      "name": "1) Setup Plan (Admin)",
      "item": [
        {
          "name": "Set INMOBILIARIA plan",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"plan\": \"INMOBILIARIA\"\n}"
            },
            "url": "{{baseUrl}}/users/{{inmoUserId}}"
          }
        },
        {
          "name": "Set BROKER plan",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
