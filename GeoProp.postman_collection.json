    "description": "Coleccion para validar endpoints nuevos de /me, /properties y /alerts con reglas por plan."
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3001/api" },
    { "key": "adminEmail", "value": "admin@geoprop.dev" },
    { "key": "adminPassword", "value": "123456" },
    { "key": "freeEmail", "value": "free@geoprop.dev" },
    { "key": "freePassword", "value": "123456" },
    { "key": "inmoEmail", "value": "inmo@geoprop.dev" },
    { "key": "inmoPassword", "value": "123456" },
    { "key": "brokerEmail", "value": "broker@geoprop.dev" },
